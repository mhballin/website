---
import { CONTACT_EMAIL } from "../config";
import ContactMenu from "./ContactMenu.tsx";

export interface Props {
  sideBarActiveItemID: string;
}

const { sideBarActiveItemID } = Astro.props;
---

<ul class="menu grow shrink menu-md overflow-y-auto" data-active-item={sideBarActiveItemID}>
    <li><a class="py-3 text-base" id="home" href="/">Home</a></li>
    <li><a class="py-3 text-base" id="work" href="/work">Projects & Work</a></li>
    <li><a class="py-3 text-base" id="cv" href="/cv">CV</a></li>
    <li>
        <!--@email_off-->
        <ContactMenu email={CONTACT_EMAIL} variant="sidebar" client:load />
        <!--@email_on-->
    </li>
</ul>

<script>
  function setActiveMenuItem() {
    const menu = document.querySelector<HTMLElement>('ul.menu');
    if (!menu) return;

    const sideBarActiveItemID = menu.dataset.activeItem;
    if (!sideBarActiveItemID) return;

    const activeItemElem = document.getElementById(sideBarActiveItemID);
    if (activeItemElem) {
      activeItemElem.classList.add('bg-base-300');
    }
  }

  function cleanupActiveMenuItem() {
    // Remove bg-base-300 from all menu items (anchors, buttons, and menu triggers)
    const menuItems = document.querySelectorAll('ul.menu a, ul.menu button, ul.menu [data-menu-trigger]');
    menuItems.forEach(item => item.classList.remove('bg-base-300'));
  }

  // Set active item on initial load
  setActiveMenuItem();

  // Cleanup before navigation
  document.addEventListener('astro:before-swap', cleanupActiveMenuItem);

  // Re-apply after navigation
  document.addEventListener('astro:page-load', setActiveMenuItem);
</script>
